<div class="admin-products">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="admin-page-title mb-0">Quản lý Sản phẩm</h1>
        <a href="/admin/product/add" class="btn btn-premium btn-premium-primary">
            <i class="fas fa-plus mr-2"></i> Thêm sản phẩm
        </a>
    </div>

    <!-- Stats -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="premium-card p-3 text-center">
                <div class="text-secondary small font-weight-bold mb-1">TỔNG SẢN PHẨM</div>
                <div class="h4 font-weight-bold mb-0">{{stats.totalProducts}}</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="premium-card p-3 text-center border-success" style="border-width: 2px;">
                <div class="text-success small font-weight-bold mb-1">CÒN HÀNG</div>
                <div class="h4 font-weight-bold mb-0 text-success">{{stats.inStock}}</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="premium-card p-3 text-center border-warning" style="border-width: 2px;">
                <div class="text-warning small font-weight-bold mb-1">SẮP HẾT</div>
                <div class="h4 font-weight-bold mb-0 text-warning">{{stats.lowStock}}</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="premium-card p-3 text-center border-danger" style="border-width: 2px;">
                <div class="text-danger small font-weight-bold mb-1">HẾT HÀNG</div>
                <div class="h4 font-weight-bold mb-0 text-danger">{{stats.outOfStock}}</div>
            </div>
        </div>
    </div>

    <div class="premium-card">
        <div class="table-responsive">
            <table class="table premium-table mb-0">
                <thead>
                    <tr>
                        <th style="width: 80px;">Ảnh</th>
                        <th>Thông tin sản phẩm</th>
                        <th>Danh mục</th>
                        <th>Giá bán</th>
                        <th>Số lượng</th>
                        <th>Trạng thái</th>
                        <th class="text-right">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each products}}
                    <tr>
                        <td>
                            <img src="{{this.image}}" alt="{{this.name}}" class="rounded-lg"
                                style="width: 50px; height: 50px; object-fit: cover; border: 1px solid var(--border);">
                        </td>
                        <td>
                            <div class="font-weight-600 text-truncate" style="max-width: 200px;">{{this.name}}</div>
                            <div class="small text-secondary">Mã: {{this.code}}</div>
                        </td>
                        <td>
                            <span class="badge badge-light border">{{this.category}}</span>
                        </td>
                        <td class="font-weight-bold text-primary">
                            {{formatCurrency this.price}}
                        </td>
                        <td>
                            <span class="font-weight-600 {{#if (eq this.quantity 0)}}text-danger{{/if}}">
                                {{this.quantity}}
                            </span>
                        </td>
                        <td>
                            <span
                                class="badge badge-pill {{#if (eq this.status 'active')}}badge-success{{else}}badge-secondary{{/if}}">
                                {{this.status}}
                            </span>
                        </td>
                        <td class="text-right">
                            <div class="btn-group">
                                <a href="/admin/product/edit/{{this._id}}" class="btn btn-sm btn-outline-primary mr-1"
                                    style="border-radius: 8px;"><i class="fas fa-edit"></i></a>
                                <a href="/admin/product/delete/{{this._id}}" class="btn btn-sm btn-outline-danger"
                                    style="border-radius: 8px;" onclick="return confirm('Xác nhận xóa?')"><i
                                        class="fas fa-trash"></i></a>
                            </div>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>