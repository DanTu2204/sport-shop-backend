<div class="container-fluid mb-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark mb-1"><i class="fa fa-users text-primary mr-2"></i>Quản lý khách hàng</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-light px-3 py-2 rounded">
                    <li class="breadcrumb-item">
                        <a href="/admin" class="text-primary"><i class="fa fa-home mr-1"></i>Dashboard</a>
                    </li>
                    <li class="breadcrumb-item active">Khách hàng</li>
                </ol>
            </nav>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <span><i class="fa fa-address-book mr-2"></i>Danh sách khách hàng</span>
        <button class="btn btn-light btn-sm text-primary">
            <i class="fa fa-download mr-1"></i>Xuất dữ liệu
        </button>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr class="text-center text-dark">
                        <th>ID</th>
                        <th>Họ tên</th>
                        <th>Email</th>
                        <th>Số điện thoại</th>
                        <th>Tổng đơn</th>
                        <th>Trạng thái</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each customers}}
                    <tr class="text-center">
                        <td>{{add @index 1}}</td>
                        <td class="fw-bold">{{this.name}}</td>
                        <td>{{this.email}}</td>
                        <td>N/A</td> 
                        <td><span class="badge bg-light text-dark border">{{this.orderCount}} đơn</span></td>
                        <td><span class="badge bg-success text-white">Hoạt động</span></td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#customerDetail{{@index}}">
                                <i class="fa fa-eye mr-1"></i>Xem
                            </button>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Chi tiết khách hàng -->
{{#each customers}}
<div class="modal fade" id="customerDetail{{@index}}" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog text-dark">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Thông tin khách hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="text-center mb-4">
                    <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px; font-size: 2rem;">
                        {{#if this.name}}{{this.name.[0]}}{{else}}U{{/if}}
                    </div>
                </div>
                <table class="table table-sm">
                    <tr>
                        <th width="40%">Họ tên:</th>
                        <td>{{this.name}}</td>
                    </tr>
                    <tr>
                        <th>Email:</th>
                        <td>{{this.email}}</td>
                    </tr>
                    <tr>
                        <th>Tổng số đơn hàng:</th>
                        <td><span class="badge bg-primary">{{this.orderCount}} đơn hàng</span></td>
                    </tr>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary text-white" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>
{{/each}}