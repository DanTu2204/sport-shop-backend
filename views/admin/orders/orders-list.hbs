<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Quản lý Đơn hàng</h4>
                <div class="table-responsive">
                    <table class="table table-striped table-bordered zero-configuration">
                        <thead>
                            <tr>
                                <th>Mã Đơn</th>
                                <th>Khách hàng</th>
                                <th>Sản phẩm</th>
                                <th>Ngày đặt</th>
                                <th>Tổng tiền</th>
                                <th>Trạng thái & Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each orders}}
                            <tr>
                                <td><small>{{this._id}}</small></td>
                                <td>
                                    <strong>{{this.contact.firstName}} {{this.contact.lastName}}</strong><br>
                                    <small>{{this.contact.email}}</small><br>
                                    <small>{{this.contact.phone}}</small>
                                </td>
                                <td>
                                    <ul style="list-style-type: none; padding: 0; margin: 0;">
                                        {{#each this.items}}
                                        <li>- {{this.name}} <span class="text-muted">(x{{this.quantity}})</span></li>
                                        {{/each}}
                                    </ul>
                                </td>
                                <td>{{formatDate this.createdAt}}</td>
                                <td>{{formatCurrency this.totalPrice}}</td>
                                <td>
                                    <div class="d-flex flex-column align-items-center">
                                        <div class="mb-2">
                                            {{#if_eq this.status 'pending'}}
                                            <span class="badge bg-warning text-dark" style="font-weight: bold;">Chờ xử lý</span>
                                            {{/if_eq}}
                                            {{#if_eq this.status 'confirmed'}}
                                            <span class="badge bg-info text-white">Đã xác nhận</span>
                                            {{/if_eq}}
                                            {{#if_eq this.status 'shipping'}}
                                            <span class="badge bg-primary text-white">Đang giao</span>
                                            {{/if_eq}}
                                            {{#if_eq this.status 'completed'}}
                                            <span class="badge bg-success text-white">Hoàn thành</span>
                                            {{/if_eq}}
                                            {{#if_eq this.status 'cancelled'}}
                                            <span class="badge bg-danger text-white">Đã hủy</span>
                                            {{/if_eq}}
                                        </div>
                                        <form action="/admin/orders/update-status" method="POST" class="w-100 mb-1">
                                            <input type="hidden" name="orderId" value="{{this._id}}">
                                            <select name="status" class="form-control form-control-sm"
                                                onchange="this.form.submit()" style="border: 1px solid #ced4da; font-size: 12px;">
                                                <option value="" disabled selected>— Đổi trạng thái —</option>
                                                <option value="pending">Chờ xử lý</option>
                                                <option value="confirmed">Xác nhận</option>
                                                <option value="shipping">Giao hàng</option>
                                                <option value="completed">Hoàn thành</option>
                                                <option value="cancelled">Hủy</option>
                                            </select>
                                        </form>
                                        <button type="button" class="btn btn-sm btn-info text-white w-100 mb-1" data-bs-toggle="modal"
                                            data-bs-target="#orderDetail{{this._id}}" style="font-size: 12px;">
                                            Xem chi tiết
                                        </button>
                                        <form action="/admin/orders/delete" method="POST" class="w-100" onsubmit="return confirm('Bạn có chắc chắn muốn xóa đơn hàng này vĩnh viễn không? Thao tác này không thể hoàn tác.')">
                                            <input type="hidden" name="orderId" value="{{this._id}}">
                                            <button type="submit" class="btn btn-sm btn-danger text-white w-100" style="font-size: 12px;">
                                                Xóa đơn
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tách riêng Modal ra khỏi Table để tránh vỡ giao diện -->
{{#each orders}}
<div class="modal fade" id="orderDetail{{this._id}}" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg text-dark">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Chi tiết đơn hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <h6>Thông tin giao hàng</h6>
                <p>
                    <strong>Địa chỉ:</strong> {{this.contact.address}}, {{this.contact.district}}, {{this.contact.city}}<br>
                    <strong>SĐT:</strong> {{this.contact.phone}}<br>
                    <strong>Thanh toán:</strong> {{this.paymentMethod}}
                </p>
                <hr>
                <h6>Sản phẩm</h6>
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Sản phẩm</th>
                            <th>Giá</th>
                            <th>SL</th>
                            <th>Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each this.items}}
                        <tr>
                            <td>{{this.name}}</td>
                            <td>{{formatCurrency this.price}}</td>
                            <td>{{this.quantity}}</td>
                            <td>{{formatCurrency (multiply this.price this.quantity)}}</td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary text-white" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>
{{/each}}