<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Quản lý Đơn hàng</h4>
                <div class="table-responsive">
                    <table class="table table-striped table-bordered zero-configuration">
                        <thead>
                            <tr>
                                <th>Mã Đơn</th>
                                <th>Khách hàng</th>
                                <th>Sản phẩm</th>
                                <th>Ngày đặt</th>
                                <th>Tổng tiền</th>
                                <th>Trạng thái</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each orders}}
                            <tr>
                                <td>{{this._id}}</td>
                                <td>
                                    <strong>{{this.contact.firstName}} {{this.contact.lastName}}</strong><br>
                                    <small>{{this.contact.email}}</small><br>
                                    <small>{{this.contact.phone}}</small>
                                </td>
                                <td>
                                    <ul style="list-style-type: none; padding: 0; margin: 0;">
                                        {{#each this.items}}
                                        <li>- {{this.name}} <span class="text-muted">(x{{this.quantity}})</span></li>
                                        {{/each}}
                                    </ul>
                                </td>
                                <td>{{this.createdAt}}</td>
                                <td>{{formatCurrency this.totalPrice}}</td>
                                <td>
                                    {{#if_eq this.status 'pending'}}
                                    <span class="badge badge-warning text-dark" style="color: #000 !important;">Chờ xử lý</span>
                                    {{/if_eq}}
                                    {{#if_eq this.status 'confirmed'}}
                                    <span class="badge badge-info text-white">Đã xác nhận</span>
                                    {{/if_eq}}
                                    {{#if_eq this.status 'shipping'}}
                                    <span class="badge badge-primary text-white">Đang giao</span>
                                    {{/if_eq}}
                                    {{#if_eq this.status 'completed'}}
                                    <span class="badge badge-success text-white">Hoàn thành</span>
                                    {{/if_eq}}
                                    {{#if_eq this.status 'cancelled'}}
                                    <span class="badge badge-danger text-white">Đã hủy</span>
                                    {{/if_eq}}
                                </td>
                                <td>
                                    <div class="d-flex flex-column align-items-center">
                                        <form action="/admin/orders/update-status" method="POST" class="w-100 mb-1">
                                            <input type="hidden" name="orderId" value="{{this._id}}">
                                            <select name="status" class="form-control form-control-sm"
                                                onchange="this.form.submit()" style="border: 1px solid #ced4da;">
                                                <option value="pending" {{#if_eq this.status 'pending' }}selected{{/if_eq}}>
                                                    Chờ xử lý</option>
                                                <option value="confirmed" {{#if_eq this.status 'confirmed'
                                                    }}selected{{/if_eq}}>Xác nhận</option>
                                                <option value="shipping" {{#if_eq this.status 'shipping'
                                                    }}selected{{/if_eq}}>Giao hàng</option>
                                                <option value="completed" {{#if_eq this.status 'completed'
                                                    }}selected{{/if_eq}}>Hoàn thành</option>
                                                <option value="cancelled" {{#if_eq this.status 'cancelled'
                                                    }}selected{{/if_eq}}>Hủy</option>
                                            </select>
                                        </form>
                                        <button type="button" class="btn btn-sm btn-info text-white w-100" data-toggle="modal"
                                            data-target="#orderDetail{{this._id}}">
                                            Xem chi tiết
                                        </button>
                                    </div>

                                    <!-- Modal Chi tiết -->
                                    <div class="modal fade" id="orderDetail{{this._id}}" tabindex="-1" role="dialog"
                                        aria-hidden="true">
                                        <div class="modal-dialog modal-lg">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Chi tiết đơn hàng {{this._id}}</h5>
                                                    <button type="button" class="close"
                                                        data-dismiss="modal"><span>&times;</span></button>
                                                </div>
                                                <div class="modal-body">
                                                    <h6>Thông tin giao hàng</h6>
                                                    <p>
                                                        <strong>Địa chỉ:</strong> {{this.contact.address}},
                                                        {{this.contact.district}}, {{this.contact.city}}<br>
                                                        <strong>SĐT:</strong> {{this.contact.phone}}<br>
                                                        <strong>Thanh toán:</strong> {{this.paymentMethod}}
                                                    </p>
                                                    <hr>
                                                    <h6>Sản phẩm</h6>
                                                    <table class="table table-sm">
                                                        <thead>
                                                            <tr>
                                                                <th>Sản phẩm</th>
                                                                <th>Giá</th>
                                                                <th>SL</th>
                                                                <th>Thành tiền</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            {{#each this.items}}
                                                            <tr>
                                                                <td>{{this.name}}</td>
                                                                <td>{{formatCurrency this.price}}</td>
                                                                <td>{{this.quantity}}</td>
                                                                <td>{{formatCurrency (multiply this.price
                                                                    this.quantity)}}</td>
                                                            </tr>
                                                            {{/each}}
                                                        </tbody>
                                                    </table>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary"
                                                        data-dismiss="modal">Đóng</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                            {{/each}}
                        </tbody>
                        <tfoot>
                            <tr>
                                <th>Mã Đơn</th>
                                <th>Khách hàng</th>
                                <th>Sản phẩm</th>
                                <th>Ngày đặt</th>
                                <th>Tổng tiền</th>
                                <th>Trạng thái</th>
                                <th>Hành động</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>