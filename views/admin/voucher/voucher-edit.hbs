<!-- Header Section -->
<div class="container-fluid mb-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark mb-1"><i class="fas fa-edit text-primary mr-2"></i>Chỉnh sửa mã giảm giá</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-light px-3 py-2 rounded">
                    <li class="breadcrumb-item">
                        <a href="/admin" class="text-primary"><i class="fa fa-home mr-1"></i>Dashboard</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a href="/admin/voucher" class="text-primary">Mã giảm giá</a>
                    </li>
                    <li class="breadcrumb-item active">Chỉnh sửa</li>
                </ol>
            </nav>
        </div>
    </div>
</div>

<!-- Form -->
<div class="card shadow-sm border-0">
    <div class="card-header bg-light">
        <h6 class="mb-0 text-dark">Thông tin mã giảm giá</h6>
    </div>
    <div class="card-body">
        <form action="/admin/voucher/edit/{{voucher._id}}" method="POST">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label>Mã giảm giá <span class="text-danger">*</span></label>
                    <input type="text" name="code" class="form-control" value="{{voucher.code}}" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label>Loại giảm giá <span class="text-danger">*</span></label>
                    <select name="type" class="form-control" required>
                        <option value="percent" {{#if_eq voucher.type 'percent' }}selected{{/if_eq}}>Phần trăm (%)
                        </option>
                        <option value="fixed" {{#if_eq voucher.type 'fixed' }}selected{{/if_eq}}>Số tiền cố định (VND)
                        </option>
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label id="valueLabel">Giá trị giảm <span class="text-danger">*</span></label>
                    <input type="number" name="value" id="valueInput" class="form-control" value="{{voucher.value}}" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label>Số lượng tối đa</label>
                    <input type="number" name="maxUsage" class="form-control" value="{{voucher.maxUsage}}"
                        placeholder="Để trống = không giới hạn">
                </div>
                <div class="col-md-6 mb-3">
                    <label>Ngày bắt đầu <span class="text-danger">*</span></label>
                    <input type="date" name="startDate" class="form-control" value="{{voucher.startDateValue}}"
                        required>
                </div>
                <div class="col-md-6 mb-3">
                    <label>Ngày kết thúc <span class="text-danger">*</span></label>
                    <input type="date" name="endDate" class="form-control" value="{{voucher.endDateValue}}" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label>Giá trị đơn hàng tối thiểu (VND)</label>
                    <input type="number" name="minOrderValue" class="form-control" value="{{voucher.minOrderValue}}"
                        placeholder="0 = không giới hạn">
                </div>
                <div class="col-md-6 mb-3">
                    <label>Trạng thái</label>
                    <select name="status" class="form-control">
                        <option value="active" {{#if_eq voucher.status 'active' }}selected{{/if_eq}}>Hoạt động</option>
                        <option value="inactive" {{#if_eq voucher.status 'inactive' }}selected{{/if_eq}}>Tạm dừng
                        </option>
                    </select>
                </div>
                <div class="col-md-12 mb-3">
                    <label>Mô tả</label>
                    <textarea name="description" class="form-control" rows="3">{{voucher.description}}</textarea>
                </div>
            </div>
            <div class="d-flex justify-content-end">
                <a href="/admin/voucher" class="btn btn-secondary mr-2">Hủy</a>
                <button type="submit" class="btn btn-primary">Cập nhật</button>
            </div>
        </form>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const typeSelect = document.querySelector('select[name="type"]');
        const valueLabel = document.getElementById('valueLabel');
        const valueInput = document.getElementById('valueInput');

        function updateLabels() {
            const type = typeSelect.value;
            if (type === 'percent') {
                valueLabel.innerHTML = 'Mức giảm (%) <span class="text-danger">*</span>';
                valueInput.placeholder = 'VD: 10, 20...';
            } else if (type === 'fixed') {
                valueLabel.innerHTML = 'Số tiền giảm (VND) <span class="text-danger">*</span>';
                valueInput.placeholder = 'VD: 50000, 100000...';
            }
        }

        typeSelect.addEventListener('change', updateLabels);
        // Initial setup
        updateLabels();
    });
</script>