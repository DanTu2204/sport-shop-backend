<!-- Breadcrumbs-->
<ol class="breadcrumb bg-light px-3 py-2 rounded shadow-sm">
    <li class="breadcrumb-item">
        <a href="/admin" class="text-primary fw-bold"><i class="fa fa-home mr-1"></i>Dashboard</a>
    </li>
    <li class="breadcrumb-item active text-dark">Tổng quan</li>
</ol>

<!-- Icon Cards-->
<div class="row">
    <div class="col-xl-3 col-sm-6 mb-4">
        <div class="card border-0 border-start border-primary border-4 shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Đơn hàng mới</div>
                        <div class="h4 mb-0 font-weight-bold text-dark">{{stats.orders}}</div>
                    </div>
                    <div class="col-auto text-primary opacity-25">
                        <i class="fas fa-shopping-cart fa-2x"></i>
                    </div>
                </div>
            </div>
            <a class="card-footer text-white clearfix small z-1 bg-primary border-0" href="/admin/orders">
                <span class="float-left">Xem chi tiết</span>
                <span class="float-right"><i class="fa fa-angle-right"></i></span>
            </a>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6 mb-4">
        <div class="card border-0 border-start border-warning border-4 shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Danh mục</div>
                        <div class="h4 mb-0 font-weight-bold text-dark">{{stats.categories}}</div>
                    </div>
                    <div class="col-auto text-warning opacity-25">
                        <i class="fas fa-list fa-2x"></i>
                    </div>
                </div>
            </div>
            <a class="card-footer text-white clearfix small z-1 bg-warning border-0" href="/admin/category">
                <span class="float-left text-dark fw-bold">Xem chi tiết</span>
                <span class="float-right text-dark"><i class="fa fa-angle-right"></i></span>
            </a>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6 mb-4">
        <div class="card border-0 border-start border-success border-4 shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Sản phẩm</div>
                        <div class="h4 mb-0 font-weight-bold text-dark">{{stats.products}}</div>
                    </div>
                    <div class="col-auto text-success opacity-25">
                        <i class="fas fa-shopping-bag fa-2x"></i>
                    </div>
                </div>
            </div>
            <a class="card-footer text-white clearfix small z-1 bg-success border-0" href="/admin/product">
                <span class="float-left">Xem chi tiết</span>
                <span class="float-right"><i class="fa fa-angle-right"></i></span>
            </a>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6 mb-4">
        <div class="card border-0 border-start border-danger border-4 shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">Khách hàng</div>
                        <div class="h4 mb-0 font-weight-bold text-dark">{{stats.customers}}</div>
                    </div>
                    <div class="col-auto text-danger opacity-25">
                        <i class="fas fa-users fa-2x"></i>
                    </div>
                </div>
            </div>
            <a class="card-footer text-white clearfix small z-1 bg-danger border-0" href="/admin/customers">
                <span class="float-left">Xem chi tiết</span>
                <span class="float-right"><i class="fa fa-angle-right"></i></span>
            </a>
        </div>
    </div>
</div>

<!-- Recent Orders Table -->
<div class="card mb-4 shadow border-0">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <span><i class="fa fa-table mr-2"></i>Đơn hàng gần đây</span>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle" id="dataTable" width="100%" cellspacing="0">
                <thead class="bg-light text-dark">
                    <tr class="text-center">
                        <th>Mã đơn</th>
                        <th>Khách hàng</th>
                        <th>Sản phẩm đầu</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th>Ngày đặt</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each recentOrders}}
                    <tr class="text-center">
                        <td class="small fw-bold">{{this._id}}</td>
                        <td>
                            {{#if this.user}}
                                <span class="text-dark">{{this.user.name}}</span>
                            {{else}}
                                <span class="text-muted">{{this.contact.firstName}} {{this.contact.lastName}}</span>
                            {{/if}}
                        </td>
                        <td class="text-left text-dark">
                            {{this.items.0.name}} 
                            {{#if (gt this.items.length 1)}}
                            <span class="badge bg-light text-dark border ms-1">+{{subtract this.items.length 1}}</span>
                            {{/if}}
                        </td>
                        <td class="fw-bold text-success">{{formatCurrency this.totalPrice}}</td>
                        <td>
                            {{#if_eq this.status 'pending'}}
                                <span class="badge bg-warning text-dark px-2 py-2">Đang xử lý</span>
                            {{else if_eq this.status 'confirmed'}}
                                <span class="badge bg-info text-white px-2 py-2">Đã xác nhận</span>
                            {{else if_eq this.status 'shipping'}}
                                <span class="badge bg-primary text-white px-2 py-2">Đang giao</span>
                            {{else if_eq this.status 'completed'}}
                                <span class="badge bg-success text-white px-2 py-2">Hoàn thành</span>
                            {{else if_eq this.status 'cancelled'}}
                                <span class="badge bg-danger text-white px-2 py-2">Đã hủy</span>
                            {{else}}
                                <span class="badge bg-secondary text-white px-2 py-2">{{this.status}}</span>
                            {{/if_eq}}
                        </td>
                        <td>{{this.createdAtFormatted}}</td>
                    </tr>
                    {{else}}
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted border-0">Chưa có đơn hàng nào.</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer small text-muted bg-white border-top-0">
        <i class="fas fa-clock mr-1"></i> Cập nhật mới nhất: {{formatDate stats.lastUpdate}}
    </div>
</div>