<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login - SportShop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            max-width: 400px;
            width: 100%;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
        }

        .login-header {
            background: #ffc107;
            color: #000;
            padding: 20px;
            text-align: center;
            border-radius: 10px 10px 0 0;
        }

        .login-body {
            background: white;
            padding: 30px;
            border-radius: 0 0 10px 10px;
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="login-card">
            <div class="login-header">
                <h3 class="mb-0"><i class="fas fa-shield-alt mr-2"></i>Admin Panel</h3>
                <p class="mb-0 small mt-2">Đăng nhập để quản lý hệ thống</p>
            </div>
            <div class="login-body">
                {{#if error}}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    {{error}}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
                {{/if}}

                <form id="adminLoginForm" method="post" data-endpoint="{{endpoint}}" data-redirect="{{next}}">
                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                            <input type="email" class="form-control" id="email" name="email"
                                placeholder="admin@admin.com" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="password" class="form-label">Mật khẩu</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-lock"></i></span>
                            <input type="password" class="form-control" id="password" name="password"
                                placeholder="******" required>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-warning btn-block w-100 mb-3">
                        <i class="fas fa-sign-in-alt mr-2"></i>Đăng nhập
                    </button>
                </form>

                <div class="text-center mt-3">
                    <small class="text-muted">
                        <i class="fas fa-info-circle"></i> Chỉ dành cho quản trị viên
                    </small>
                    <div class="mt-2">
                        <a href="/admin/register" class="small text-decoration-none">Đăng ký tài khoản Admin</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $('#adminLoginForm').submit(function (e) {
            e.preventDefault();
            const formData = $(this).serialize();
            const endpoint = $(this).data('endpoint') || '/admin/login';
            $.ajax({
                type: 'POST',
                url: endpoint,
                data: formData,
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                },
                success: function (response) {
                    if (response.success) {
                        alert(response.message);
                        window.location.href = response.redirect || '/admin/';
                    } else {
                        alert('Lỗi đăng nhập: ' + response.message);
                    }
                },
                error: function (xhr) {
                    try {
                        const errorData = JSON.parse(xhr.responseText);
                        alert('Lỗi: ' + errorData.message);
                    } catch (e) {
                        alert('Lỗi: Đã xảy ra lỗi không xác định. Vui lòng thử lại.');
                    }
                }
            });
        });
    </script>
</body>

</html>