<!-- Header Section -->
<div class="container-fluid mb-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark mb-1"><i class="fas fa-user-cog text-primary mr-2"></i>Tài khoản Admin</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-light px-3 py-2 rounded shadow-sm">
                    <li class="breadcrumb-item">
                        <a href="/admin" class="text-primary fw-bold"><i class="fa fa-home mr-1"></i>Dashboard</a>
                    </li>
                    <li class="breadcrumb-item active text-dark">Tài khoản</li>
                </ol>
            </nav>
        </div>
    </div>
</div>

<div class="row">
    <!-- Profile Info -->
    <div class="col-lg-4 mb-4">
        <div class="card shadow-sm border-0">
            <div class="card-body text-center">
                <div class="position-relative d-inline-block mb-3">
                    <img src="{{#if adminUser.image}}{{adminUser.image}}{{else}}https://www.w3schools.com/howto/img_avatar.png{{/if}}" 
                        id="avatar-preview"
                        data-original="{{#if adminUser.image}}{{adminUser.image}}{{else}}https://www.w3schools.com/howto/img_avatar.png{{/if}}"
                        class="rounded-circle border shadow-sm" alt="Admin Avatar"
                        style="width: 150px; height: 150px; object-fit: cover;">
                    
                    <label for="avatarUpload" 
                        class="position-absolute border-0 bg-primary text-white rounded-circle d-flex align-items-center justify-content-center shadow"
                        style="bottom: 5px; right: 5px; width: 40px; height: 40px; cursor: pointer; transition: all 0.3s;">
                        <i class="fas fa-camera"></i>
                    </label>
                </div>

                <!-- Avatar Actions (Hidden by default) -->
                <div id="avatar-actions" class="mb-3 d-none animate__animated animate__fadeIn">
                    <button type="button" class="btn btn-sm btn-success px-3 shadow-sm mr-1" onclick="submitProfileForm()">
                        <i class="fas fa-check mr-1"></i> Lưu ảnh
                    </button>
                    <button type="button" class="btn btn-sm btn-danger px-3 shadow-sm" onclick="cancelAvatarSelection()">
                        <i class="fas fa-times mr-1"></i> Hủy
                    </button>
                </div>

                <h5 class="mb-1 text-dark fw-bold">{{adminUser.name}}</h5>
                <p class="text-muted mb-3">{{adminUser.email}}</p>
                <p class="badge bg-light text-primary border border-primary px-3 py-2">Quản trị viên hệ thống</p>
                <hr>
                <div class="text-left px-3">
                    <p class="mb-2 text-dark"><strong>Vai trò:</strong> 
                        {{#if_eq adminUser.role 'admin'}}Admin{{else}}Nhân viên{{/if_eq}}
                    </p>
                    <p class="mb-2 text-dark"><strong>ID:</strong> <small class="text-muted">{{adminUser._id}}</small></p>
                    <p class="mb-0 text-dark">
                        <strong>Trạng thái:</strong>
                        <span class="badge bg-success text-white">Hoạt động</span>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Profile Form -->
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-bottom py-3">
                <h6 class="mb-0 text-dark fw-bold">Chỉnh sửa thông tin cá nhân</h6>
            </div>
            <div class="card-body">
                <form id="profileForm" action="/admin/profile/update" method="POST" enctype="multipart/form-data">
                    <input type="file" id="avatarUpload" name="image" class="form-control-file"
                        style="display: none;"
                        onchange="handleAvatarChange(this)">
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="text-dark small fw-bold">Họ và tên <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="name" value="{{adminUser.name}}" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-dark small fw-bold">Email <span class="text-danger">*</span></label>
                            <input type="email" class="form-control bg-light" name="email" value="{{adminUser.email}}" 
                                required readonly title="Không thể thay đổi Email">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-dark small fw-bold">Số điện thoại</label>
                            <input type="text" class="form-control" name="phone" value="{{adminUser.phone}}"
                                placeholder="0909 123 456">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-dark small fw-bold">Ngày sinh</label>
                            <input type="date" class="form-control" name="birthday"
                                value="{{formatDateValue adminUser.birthday}}">
                        </div>
                        <div class="col-md-12 mb-3">
                            <label class="text-dark small fw-bold">Địa chỉ</label>
                            <input type="text" class="form-control" name="address" value="{{adminUser.address}}"
                                placeholder="123 Nguyễn Trãi, Quận 5, TP.HCM">
                        </div>
                        <div class="col-md-12 mb-4">
                            <label class="text-dark small fw-bold">Giới thiệu ngắn</label>
                            <textarea class="form-control" name="intro" rows="3"
                                placeholder="Ghi chú về bản thân...">{{adminUser.intro}}</textarea>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end border-top pt-3">
                        <button type="submit" class="btn btn-primary px-4 py-2 fw-bold">
                            <i class="fas fa-save mr-2"></i>Lưu thay đổi
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Change Password -->
        <div class="card shadow-sm border-0 mt-4">
            <div class="card-header bg-white border-bottom py-3">
                <h6 class="mb-0 text-dark fw-bold">Đổi mật khẩu bảo mật</h6>
            </div>
            <div class="card-body">
                <form action="/admin/profile/password" method="POST">
                    <div class="mb-3">
                        <label class="text-dark small fw-bold">Mật khẩu hiện tại</label>
                        <input type="password" class="form-control" name="currentPassword" required>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="text-dark small fw-bold">Mật khẩu mới</label>
                            <input type="password" class="form-control" name="newPassword" required minlength="6">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-dark small fw-bold">Xác nhận mật khẩu mới</label>
                            <input type="password" class="form-control" name="confirmPassword" required minlength="6">
                        </div>
                    </div>
                    <div class="d-flex justify-content-end border-top pt-3">
                        <button type="submit" class="btn btn-warning px-4 py-2 fw-bold text-dark">
                            <i class="fas fa-key mr-2"></i>Thay đổi mật khẩu
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function handleAvatarChange(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('avatar-preview').src = e.target.result;
                document.getElementById('avatar-actions').classList.remove('d-none');
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

    function cancelAvatarSelection() {
        const preview = document.getElementById('avatar-preview');
        preview.src = preview.getAttribute('data-original');
        document.getElementById('avatarUpload').value = '';
        document.getElementById('avatar-actions').classList.add('d-none');
    }

    function submitProfileForm() {
        document.getElementById('profileForm').submit();
    }
</script>