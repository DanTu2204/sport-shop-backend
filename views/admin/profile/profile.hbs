<!-- Header Section -->
<div class="container-fluid mb-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark mb-1"><i class="fas fa-user-cog text-primary mr-2"></i>Tài khoản Admin</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-light px-3 py-2 rounded">
                    <li class="breadcrumb-item">
                        <a href="/admin" class="text-primary"><i class="fa fa-home mr-1"></i>Dashboard</a>
                    </li>
                    <li class="breadcrumb-item active">Tài khoản</li>
                </ol>
            </nav>
        </div>
    </div>
</div>

<div class="row">
    <!-- Profile Info -->
    <div class="col-lg-4 mb-4">
        <div class="card shadow-sm border-0">
            <div class="card-body text-center">
                <img src="{{#if adminUser.image}}{{adminUser.image}}{{else}}/img/{{/if}}" id="avatar-preview"
                    class="rounded-circle mb-3" alt="Admin Avatar"
                    style="width: 150px; height: 150px; object-fit: cover;">
                <h5 class="mb-1">{{adminUser.name}}</h5>
                <p class="text-muted mb-3">{{adminUser.email}}</p>
                <p class="text-muted small">Quản trị viên hệ thống</p>
                <hr>
                <div class="text-left">
                    <p class="mb-2"><strong>Vai trò:</strong> {{#if (eq adminUser.role
                        'admin')}}Admin{{else}}User{{/if}}</p>
                    <p class="mb-2"><strong>ID:</strong> {{adminUser._id}}</p>
                    <p class="mb-0">
                        <strong>Trạng thái:</strong>
                        <span class="badge badge-success" style="color: #000;">Hoạt động</span>
                    </p>

                </div>
            </div>
        </div>
    </div>

    <!-- Edit Profile Form -->
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-light">
                <h6 class="mb-0 text-dark">Chỉnh sửa thông tin</h6>
            </div>
            <div class="card-body">
                <form action="/admin/profile/update" method="POST" enctype="multipart/form-data">
                    <div class="row">
                        <div class="col-md-12 mb-3 text-center">
                            <!-- Hidden file input triggered by image click or separate button -->
                            <label for="avatarUpload" style="cursor: pointer;">
                                <span class="badge badge-primary">Thay đổi ảnh đại diện</span>
                            </label>
                            <input type="file" id="avatarUpload" name="image" class="form-control-file"
                                style="display: none;"
                                onchange="document.getElementById('avatar-preview').src = window.URL.createObjectURL(this.files[0])">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label>Họ và tên <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="name" value="{{adminUser.name}}" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label>Email <span class="text-danger">*</span></label>
                            <input type="email" class="form-control" name="email" value="{{adminUser.email}}" required
                                readonly>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label>Số điện thoại</label>
                            <input type="text" class="form-control" name="phone" value="{{adminUser.phone}}"
                                placeholder="0909 123 456">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label>Ngày sinh</label>
                            <input type="date" class="form-control" name="birthday"
                                value="{{formatDateValue adminUser.birthday}}">
                        </div>
                        <div class="col-md-12 mb-3">
                            <label>Địa chỉ</label>
                            <input type="text" class="form-control" name="address" value="{{adminUser.address}}"
                                placeholder="123 Nguyễn Trãi, Quận 5, TP.HCM">
                        </div>
                        <div class="col-md-12 mb-3">
                            <label>Giới thiệu</label>
                            <textarea class="form-control" name="intro" rows="3"
                                placeholder="Giới thiệu bản thân...">{{adminUser.intro}}</textarea>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary">Cập nhật thông tin</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Change Password -->
        <div class="card shadow-sm border-0 mt-4">
            <div class="card-header bg-light">
                <h6 class="mb-0 text-dark">Đổi mật khẩu</h6>
            </div>
            <div class="card-body">
                <form action="/admin/profile/password" method="POST">
                    <div class="mb-3">
                        <label>Mật khẩu hiện tại <span class="text-danger">*</span></label>
                        <input type="password" class="form-control" name="currentPassword" required>
                    </div>
                    <div class="mb-3">
                        <label>Mật khẩu mới <span class="text-danger">*</span></label>
                        <input type="password" class="form-control" name="newPassword" required>
                    </div>
                    <div class="mb-3">
                        <label>Xác nhận mật khẩu mới <span class="text-danger">*</span></label>
                        <input type="password" class="form-control" name="confirmPassword" required>
                    </div>
                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-warning">Đổi mật khẩu</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>