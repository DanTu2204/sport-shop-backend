<!-- Header Section -->
<div class="container-fluid mb-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark mb-1"><i class="fa fa-list text-primary mr-2"></i>Product Categories</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-light px-3 py-2 rounded">
                    <li class="breadcrumb-item">
                        <a href="/admin" class="text-primary"><i class="fa fa-home mr-1"></i>Dashboard</a>
                    </li>
                    <li class="breadcrumb-item active">Categories Management</li>
                </ol>
            </nav>
        </div>
        <a href="/admin/category/add" class="btn btn-primary btn-lg">
            <i class="fa fa-plus-circle mr-2"></i>Add New Category
        </a>
    </div>
</div>

<!-- Stats Cards -->
<!-- Stats Cards -->
<div class="row mb-4">
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">New Orders</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">{{stats.totalOrders}}</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-shopping-cart fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-warning shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Categories</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">{{stats.totalCategories}}</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-list fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-success shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Products</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">{{stats.totalProducts}}</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-shopping-bag fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-danger shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">Customers</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">{{stats.totalCustomers}}</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-users fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Categories Grid -->
<div class="row">
    {{#each categories}}
    <div class="col-lg-4 mb-4">
        <div class="card category-card shadow-sm border-0 h-100">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h6 class="mb-0">{{this.name}}</h6>
                <span class="badge badge-light">{{this.productCount}} products</span>
            </div>
            <div class="card-body">
                <p class="text-muted mb-3">{{this.description}}</p>
                <div class="d-flex justify-content-between align-items-center">
                    <span
                        class="badge {{#if (eq this.status 'active')}}badge-success{{else}}badge-secondary{{/if}}">{{this.status}}</span>
                    <small class="text-muted">Created: {{this.createdAtFormatted}}</small>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0">
                <div class="btn-group w-100">
                    <!-- Edit button removed -->
                    <form action="/admin/category/delete" method="POST" class="w-100"
                        onsubmit="return confirm('Delete this category?');">
                        <input type="hidden" name="id" value="{{this._id}}">
                        <button class="btn btn-outline-danger btn-sm w-100 rounded-0"
                            style="border-radius: 0 0.2rem 0.2rem 0 !important;">
                            <i class="fa fa-trash mr-1"></i>Delete
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    {{/each}}

    <!-- Add New Category Card -->
    <div class="col-lg-4 mb-4">
        <div class="card border-dashed shadow-sm h-100">
            <div class="card-body d-flex flex-column justify-content-center align-items-center text-center py-5">
                <i class="fa fa-plus-circle fa-3x text-muted mb-3"></i>
                <h5 class="text-muted mb-2">Add New Category</h5>
                <p class="text-muted mb-3">Create a new product category</p>
                <a href="/admin/category/add" class="btn btn-primary">
                    <i class="fa fa-plus mr-2"></i>Add Category
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="card shadow-sm border-0 mt-4">
    <div class="card-header bg-light">
        <h6 class="mb-0 text-dark">Quick Actions</h6>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-3 mb-3">
                <a href="/admin/category/export" class="btn btn-outline-primary btn-block">
                    <i class="fa fa-download mr-2"></i>Export Categories
                </a>
            </div>
            <div class="col-md-3 mb-3">
                <a href="/admin/category/import" class="btn btn-outline-success btn-block">
                    <i class="fa fa-upload mr-2"></i>Import Categories
                </a>
            </div>
            <div class="col-md-3 mb-3">
                <button class="btn btn-outline-warning btn-block">
                    <i class="fa fa-sync mr-2"></i>Refresh Data
                </button>
            </div>
            <div class="col-md-3 mb-3">
                <button class="btn btn-outline-info btn-block">
                    <i class="fa fa-chart-pie mr-2"></i>View Reports
                </button>
            </div>
        </div>
    </div>
</div>