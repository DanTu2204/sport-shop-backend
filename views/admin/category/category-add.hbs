<div class="container-fluid mb-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark mb-1"><i class="fa fa-plus-circle text-primary mr-2"></i>Thêm danh mục mới</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-light px-3 py-2 rounded">
                    <li class="breadcrumb-item">
                        <a href="/admin" class="text-primary"><i class="fa fa-home mr-1"></i>Dashboard</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a href="/admin/category" class="text-primary">Categories</a>
                    </li>
                    <li class="breadcrumb-item active">Add Category</li>
                </ol>
            </nav>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-light">
        <h5 class="mb-0 text-dark">Thông tin danh mục</h5>
    </div>
    <div class="card-body">
        <form method="POST" action="/admin/category/add">
            <div class="mb-3">
                <label class="form-label">Tên danh mục</label>
                <input type="text" name="name" class="form-control" placeholder="Nhập tên danh mục" required>
            </div>
            <div class="mb-3">
                <label class="form-label">Mô tả</label>
                <textarea class="form-control" name="description" rows="3"
                    placeholder="Mô tả ngắn về danh mục"></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">Trạng thái</label>
                <select class="form-select form-control" name="status">
                    <option value="active" selected>Đang hoạt động</option>
                    <option value="inactive">Ẩn</option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary">
                <i class="fa fa-save mr-2"></i>Lưu danh mục
            </button>
            <a href="/admin/category" class="btn btn-secondary ml-2">Hủy</a>
        </form>
    </div>
</div>