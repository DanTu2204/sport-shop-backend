<div class="container-fluid mb-4">
    <h2 class="text-dark mb-3"><i class="fa fa-upload text-success mr-2"></i>Import Categories</h2>
    <p class="text-muted">Trang demo import danh mục (upload file Excel/CSV).</p>
    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body">
            <form>
                <div class="mb-3">
                    <label class="form-label">Chọn file</label>
                    <input type="file" class="form-control">
                </div>
                <button type="submit" class="btn btn-success">
                    <i class="fa fa-upload mr-2"></i>Import
                </button>
                <a href="/admin/category" class="btn btn-secondary ml-2">Hủy</a>
            </form>
        </div>
    </div>
</div>



