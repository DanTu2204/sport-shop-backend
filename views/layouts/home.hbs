<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8">
    <title>SportShop - Cửa hàng Quần áo Thể thao Online</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="Quần áo thể thao, dụng cụ tập luyện, giày thể thao" name="keywords">
    <meta content="Cửa hàng Thể thao SportShop, bán quần áo tập gym, yoga, chạy bộ" name="description">
    <base href="/">

    <link href="img/favicon.ico" rel="icon">

    <link rel="preconnect" href="https://fonts.gstatic.com">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">

    <link href="lib/animate/animate.min.css" rel="stylesheet">
    <link href="lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">

    <link href="css/style.css" rel="stylesheet">
</head>

<body>
    <div class="container-fluid">
        <div class="row bg-secondary py-1 px-xl-5">
            <div class="col-lg-6 d-none d-lg-block">
                <div class="d-inline-flex align-items-center h-100">
                    <a class="text-body mr-3" href="/about">Về chúng tôi</a>
                    <a class="text-body mr-3" href="/contact">Liên hệ</a>
                    <a class="text-body mr-3" href="/help">Trợ giúp</a>
                    <a class="text-body mr-3" href="/faq">Câu hỏi thường gặp</a>
                </div>
            </div>
            <div class="col-lg-6 text-center text-lg-right">
                <div class="d-inline-flex align-items-center">
                    <div class="btn-group">
                        <button type="button" class="btn btn-sm btn-light dropdown-toggle" data-toggle="dropdown">
                            {{#if user}}
                            Xin chào, {{user.name}}
                            {{else}}
                            Tài khoản
                            {{/if}}
                        </button>
                        <div class="dropdown-menu dropdown-menu-right">
                            {{#if user}}
                            <span class="dropdown-item-text text-muted small">{{user.email}}</span>
                            <div class="dropdown-divider"></div>
                            <a class="dropdown-item" href="/profile">Tài khoản của tôi</a>
                            <!-- Đăng xuất: dùng GET /logout để quay về trang chủ -->
                            <a class="dropdown-item text-danger" href="/logout">Đăng xuất</a>
                            {{else}}
                            <!-- Đăng nhập / Đăng ký: dùng đường dẫn /login và /register -->
                            <a class="dropdown-item" href="/login">Đăng nhập</a>
                            <a class="dropdown-item" href="/register">Đăng ký</a>
                            {{/if}}
                        </div>
                    </div>
                    <div class="btn-group mx-2">
                        <span class="btn btn-sm btn-light disabled">VND</span>
                    </div>
                    <div class="btn-group">
                        <span class="btn btn-sm btn-light disabled">Ngôn ngữ: VI</span>
                    </div>
                </div>
                <div class="d-inline-flex align-items-center d-block d-lg-none">
                    <a href="/wishlist" class="btn px-0 ml-2">
                        <i class="fas fa-heart text-dark"></i>
                        <span class="badge text-dark border border-dark rounded-circle"
                            style="padding-bottom: 2px;">{{wishlistCount}}</span>
                    </a>
                    <a href="/cart" class="btn px-0 ml-2">
                        <i class="fas fa-shopping-cart text-dark"></i>
                        <span class="badge text-dark border border-dark rounded-circle cart-count"
                            style="padding-bottom: 2px;">{{#if cart}}{{cart.length}}{{else}}0{{/if}}</span>
                    </a>
                </div>
            </div>
        </div>
        <div class="row align-items-center bg-light py-3 px-xl-5 d-none d-lg-flex">
            <div class="col-lg-4">
                <a href="/" class="text-decoration-none">
                    <span class="h1 text-uppercase text-primary bg-dark px-2">Sport</span>
                    <span class="h1 text-uppercase text-dark bg-primary px-2 ml-n1">Shop</span>
                </a>
            </div>
            <div class="col-lg-4 col-6 text-left">
                <form method="get" action="/shop">
                    <div class="input-group">
                        <input type="text" name="q" class="form-control" placeholder="Tìm kiếm sản phẩm"
                            value="{{searchQuery}}">
                        <div class="input-group-append">
                            <button type="submit" class="input-group-text bg-transparent text-primary border-0">
                                <i class="fa fa-search"></i>
                            </button>
                        </div>
                    </div>
                </form>
            </div>
            <div class="col-lg-4 col-6 text-right">
                <p class="m-0">Hỗ trợ Khách hàng</p>
                <h5 class="m-0">0909 123 456</h5>
            </div>
        </div>
    </div>

    <div class="container-fluid bg-dark mb-30">
        <div class="row px-xl-5">
            <div class="col-lg-3 d-none d-lg-block">
                <a class="btn d-flex align-items-center justify-content-between bg-primary w-100" data-toggle="collapse"
                    href="#navbar-vertical" style="height: 65px; padding: 0 30px;">
                    <h6 class="text-dark m-0"><i class="fa fa-bars mr-2"></i>Danh mục</h6>
                    <i class="fa fa-angle-down text-dark"></i>
                </a>
                <nav class="collapse position-absolute navbar navbar-vertical navbar-light align-items-start p-0 bg-light"
                    id="navbar-vertical" style="width: calc(100% - 30px); z-index: 999;">
                    <div class="navbar-nav w-100">
                        {{#each categories}}
                        <a href="/shop?category={{this.name}}" class="nav-item nav-link">{{this.name}}</a>
                        {{/each}}
                    </div>
                </nav>
            </div>
            <div class="col-lg-9">
                <nav class="navbar navbar-expand-lg bg-dark navbar-dark py-3 py-lg-0 px-0">
                    <a href="/" class="text-decoration-none d-block d-lg-none">
                        <span class="h1 text-uppercase text-dark bg-light px-2">Sport</span>
                        <span class="h1 text-uppercase text-light bg-primary px-2 ml-n1">Shop</span>
                    </a>
                    <button type="button" class="navbar-toggler" data-toggle="collapse" data-target="#navbarCollapse">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse justify-content-between" id="navbarCollapse">
                        <div class="navbar-nav mr-auto py-0">
                            <a href="/" class="nav-item nav-link">Trang chủ</a>
                            <a href="/shop" class="nav-item nav-link">Cửa hàng</a>
                            <a href="/detail" class="nav-item nav-link">Chi tiết SP</a>

                            <div class="nav-item dropdown">
                                <a href="#" class="nav-link dropdown-toggle" data-toggle="dropdown">Trang <i
                                        class="fa fa-angle-down mt-1"></i></a>
                                <div class="dropdown-menu bg-primary rounded-0 border-0 m-0">
                                    <a href="/cart" class="dropdown-item">Giỏ hàng</a>
                                    <a href="/checkout" class="dropdown-item">Thanh toán</a>
                                </div>
                            </div>
                            <a href="/contact" class="nav-item nav-link">Liên hệ</a>
                        </div>
                        <div class="navbar-nav ml-auto py-0 d-none d-lg-block">
                            <a href="/profile" class="btn px-0" title="Tài khoản của tôi">
                                <i class="fas fa-user text-primary"></i>
                            </a>
                            <a href="/wishlist" class="btn px-0 ml-3">
                                <i class="fas fa-heart text-primary"></i>
                                <span class="badge text-secondary border border-secondary rounded-circle"
                                    style="padding-bottom: 2px;">{{wishlistCount}}</span>
                            </a>
                            <a href="/cart" class="btn px-0 ml-3">
                                <i class="fas fa-shopping-cart text-primary"></i>
                                <span class="badge text-secondary border border-secondary rounded-circle cart-count"
                                    style="padding-bottom: 2px;">{{#if cart}}{{cart.length}}{{else}}0{{/if}}</span>
                            </a>
                        </div>
                    </div>
                </nav>
            </div>
        </div>
    </div>

    {{#if flash}}
    <div class="container mt-3">
        <div class="alert {{#if (eq flash.type 'success')}}alert-success{{else}}alert-danger{{/if}} alert-dismissible fade show"
            role="alert">
            {{flash.message}}
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    </div>
    {{/if}}

    <div class="container-fluid mb-3">
        {{{body}}}
    </div>

    <div class="container-fluid bg-dark text-secondary mt-5 pt-5">
        <!-- Nội dung footer giữ nguyên -->
    </div>

    <a href="#" class="btn btn-primary back-to-top"><i class="fa fa-angle-double-up"></i></a>

    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.bundle.min.js"></script>
    <script src="lib/easing/easing.min.js"></script>
    <script src="lib/owlcarousel/owl.carousel.min.js"></script>

    <script src="js/main.js"></script>
    <script>
        // Giữ query parameters (user, cart, wishlist) khi điều hướng
        (function () {
            function getParamsToKeep() {
                const urlParams = new URLSearchParams(window.location.search);
                const params = {};
                if (urlParams.get('user')) params.user = urlParams.get('user');
                if (urlParams.get('cart')) params.cart = urlParams.get('cart');
                if (urlParams.get('wishlist')) params.wishlist = urlParams.get('wishlist');
                return params;
            }

            function addParamsToUrl(url, params) {
                if (!url || Object.keys(params).length === 0) return url;

                try {
                    const urlObj = new URL(url, window.location.origin);
                    Object.keys(params).forEach(key => {
                        if (!urlObj.searchParams.has(key)) {
                            urlObj.searchParams.set(key, params[key]);
                        }
                    });
                    return urlObj.pathname + urlObj.search;
                } catch (e) {
                    // Nếu không phải absolute URL, xử lý như relative URL
                    const separator = url.includes('?') ? '&' : '?';
                    const queryParts = [];
                    Object.keys(params).forEach(key => {
                        if (!url.includes(key + '=')) {
                            queryParts.push(key + '=' + encodeURIComponent(params[key]));
                        }
                    });
                    return queryParts.length > 0 ? url + separator + queryParts.join('&') : url;
                }
            }

            function addHiddenInputsToForm(form, params) {
                if (!form || Object.keys(params).length === 0) return;

                Object.keys(params).forEach(key => {
                    // Kiểm tra xem input đã tồn tại chưa
                    const existingInput = form.querySelector(`input[name="${key}"][type="hidden"]`);
                    if (!existingInput && params[key]) {
                        const input = document.createElement('input');
                        input.type = 'hidden';
                        input.name = key;
                        input.value = params[key];
                        form.appendChild(input);
                    } else if (existingInput && params[key]) {
                        // Cập nhật giá trị nếu đã tồn tại
                        existingInput.value = params[key];
                    }
                });
            }

            // Bắt tất cả các click vào link để giữ query parameters
            document.addEventListener('click', function (e) {
                const link = e.target.closest('a[href]');
                if (!link) return;

                const href = link.getAttribute('href');
                if (!href) return;

                // Bỏ qua external links, mailto, tel, và các link đặc biệt
                if (href.startsWith('http') || href.startsWith('mailto:') || href.startsWith('tel:') ||
                    href.startsWith('#') || href === 'javascript:void(0)' || href === 'javascript:;') {
                    return;
                }

                // Bỏ qua các link logout, login, register
                if (href.includes('/logout') || href.includes('/login') || href.includes('/register')) {
                    return;
                }

                const paramsToKeep = getParamsToKeep();
                if (Object.keys(paramsToKeep).length > 0) {
                    const newHref = addParamsToUrl(href, paramsToKeep);
                    if (newHref !== href) {
                        link.setAttribute('href', newHref);
                    }
                }
            }, true); // Sử dụng capture phase để bắt sớm

            // Cập nhật tất cả các link khi trang load
            document.addEventListener('DOMContentLoaded', function () {
                const paramsToKeep = getParamsToKeep();

                if (Object.keys(paramsToKeep).length > 0) {
                    // Cập nhật tất cả các link
                    const links = document.querySelectorAll('a[href^="/"]:not([href*="logout"]):not([href*="login"]):not([href*="register"])');
                    links.forEach(link => {
                        const href = link.getAttribute('href');
                        if (href && !href.startsWith('http') && !href.startsWith('mailto:') && !href.startsWith('tel:')) {
                            const newHref = addParamsToUrl(href, paramsToKeep);
                            if (newHref !== href) {
                                link.setAttribute('href', newHref);
                            }
                        }
                    });

                    // Xử lý form GET
                    const getForms = document.querySelectorAll('form[method="get"]');
                    getForms.forEach(form => {
                        form.addEventListener('submit', function (e) {
                            const action = form.getAttribute('action') || window.location.pathname;
                            const newAction = addParamsToUrl(action, paramsToKeep);
                            if (newAction !== action) {
                                form.setAttribute('action', newAction);
                            }
                        });
                    });

                    // Xử lý form POST - thêm hidden inputs
                    const postForms = document.querySelectorAll('form[method="post"]:not(#logoutForm)');
                    postForms.forEach(form => {
                        // Thêm hidden inputs ngay khi form load
                        addHiddenInputsToForm(form, paramsToKeep);

                        // Đảm bảo thêm lại trước khi submit (với độ ưu tiên cao)
                        form.addEventListener('submit', function (e) {
                            addHiddenInputsToForm(form, paramsToKeep);
                        }, true); // Capture phase để chạy trước
                    });

                    // Sử dụng MutationObserver để theo dõi các form mới được thêm vào DOM
                    const observer = new MutationObserver(function (mutations) {
                        mutations.forEach(function (mutation) {
                            mutation.addedNodes.forEach(function (node) {
                                if (node.nodeType === 1) { // Element node
                                    // Kiểm tra nếu node là form
                                    if (node.tagName === 'FORM' && node.method === 'post' && node.id !== 'logoutForm') {
                                        addHiddenInputsToForm(node, paramsToKeep);
                                    }
                                    // Kiểm tra các form bên trong node
                                    const forms = node.querySelectorAll && node.querySelectorAll('form[method="post"]:not(#logoutForm)');
                                    if (forms) {
                                        forms.forEach(form => {
                                            addHiddenInputsToForm(form, paramsToKeep);
                                        });
                                    }
                                }
                            });
                        });
                    });

                    // Bắt đầu quan sát
                    observer.observe(document.body, {
                        childList: true,
                        subtree: true
                    });
                }

                // Xử lý form logout
                // Form logout cũ đã được thay bằng link GET /logout, không cần xử lý thêm
            });
        })();
    </script>
</body>

</html>