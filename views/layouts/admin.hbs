<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} - Admin Panel - SportShop</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #f4f6f9;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .sidebar {
            height: 100vh;
            background: #ffc107;
            color: #000;
            padding-top: 20px;
            position: fixed;
            width: 240px;
            box-shadow: 2px 0 10px rgba(0, 0, 0, 0.1);
            overflow-y: auto;
            z-index: 1000;
        }

        .sidebar h4 {
            padding: 0 20px;
            margin-bottom: 20px;
            font-size: 1.2rem;
        }

        .sidebar a {
            color: #000;
            font-weight: 500;
            display: flex;
            align-items: center;
            padding: 12px 18px;
            border-radius: 8px;
            margin: 0 10px 6px 10px;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .sidebar a:hover,
        .sidebar a.active {
            background: #000;
            color: #ffc107;
            transform: translateX(5px);
        }

        .sidebar a i {
            margin-right: 10px;
            width: 20px;
            text-align: center;
        }

        .sidebar hr {
            margin: 15px 10px;
            border-color: rgba(0, 0, 0, 0.2);
        }

        .content {
            margin-left: 260px;
            padding: 30px;
            min-height: 100vh;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .sidebar {
                width: 200px;
            }

            .content {
                margin-left: 220px;
                padding: 20px;
            }
        }

        @media (max-width: 576px) {
            .sidebar {
                width: 100%;
                height: auto;
                position: relative;
            }

            .content {
                margin-left: 0;
                padding: 15px;
            }
        }
    </style>
</head>

<body>

    <div class="sidebar">
        <h4 class="text-center fw-bold mb-4">ADMIN PANEL</h4>

        <a href="/" target="_blank">
            <i class="fas fa-home"></i> Về trang chủ
        </a>

        <hr>

        <a href="/admin" class="{{#if isDashboard}}active{{/if}}">
            <i class="fas fa-tachometer-alt"></i> Tổng quan
        </a>

        <a href="/admin/statistics" class="{{#if isStatistics}}active{{/if}}">
            <i class="fas fa-chart-line"></i> Thống kê
        </a>

        <a href="/admin/category" class="{{#if isCategory}}active{{/if}}">
            <i class="fas fa-list"></i> Danh mục
        </a>

        <a href="/admin/product" class="{{#if isProduct}}active{{/if}}">
            <i class="fas fa-box"></i> Sản phẩm
        </a>

        <a href="/admin/orders" class="{{#if isOrders}}active{{/if}}">
            <i class="fas fa-shopping-cart"></i> Đơn hàng
        </a>

        <a href="/admin/customers" class="{{#if isCustomers}}active{{/if}}">
            <i class="fas fa-users"></i> Khách hàng
        </a>

        <a href="/admin/inventory" class="{{#if isInventory}}active{{/if}}">
            <i class="fas fa-warehouse"></i> Tồn kho & Nhập hàng
        </a>

        <a href="/admin/voucher" class="{{#if isVoucher}}active{{/if}}">
            <i class="fas fa-ticket-alt"></i> Mã giảm giá
        </a>

        <a href="/admin/banner" class="{{#if isBanner}}active{{/if}}">
            <i class="fas fa-images"></i> Banner quảng cáo
        </a>

        <a href="/admin/contact" class="{{#if isContact}}active{{/if}}">
            <i class="fas fa-envelope"></i> Liên hệ
        </a>

        <hr>

        <a href="/admin/profile" class="{{#if isProfile}}active{{/if}}">
            <i class="fas fa-user-cog"></i> Tài khoản admin
        </a>

        <a href="/admin/logout">
            <i class="fas fa-sign-out-alt"></i> Đăng xuất
        </a>
    </div>

    <div class="content">
        {{{body}}}
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Giữ query parameters (đặc biệt là user info) khi điều hướng trong admin panel
        document.addEventListener('DOMContentLoaded', function () {
            const urlParams = new URLSearchParams(window.location.search);
            const userParam = urlParams.get('user');

            if (userParam) {
                // Cập nhật tất cả các link trong sidebar để giữ query parameters
                const sidebarLinks = document.querySelectorAll('.sidebar a[href^="/admin"]');
                sidebarLinks.forEach(link => {
                    const href = link.getAttribute('href');
                    if (href && !href.includes('logout') && !href.includes('login')) {
                        // Chỉ thêm user param nếu chưa có
                        if (!href.includes('?')) {
                            link.setAttribute('href', href + '?user=' + encodeURIComponent(userParam));
                        } else if (!href.includes('user=')) {
                            link.setAttribute('href', href + '&user=' + encodeURIComponent(userParam));
                        }
                    }
                });
            }
        });
    </script>
</body>

</html>