<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8">
    <title>{{title}} | Sport Shop Admin</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">

    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/css/bootstrap.min.css" rel="stylesheet">

    <style>
        :root {
            --primary: #3b82f6;
            --primary-hover: #2563eb;
            --secondary: #10b981;
            --background: #f8fafc;
            --surface: #ffffff;
            --text-primary: #1e293b;
            --text-secondary: #64748b;
            --border: #e2e8f0;
            --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
            --shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
            --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1);
            --glass-bg: rgba(255, 255, 255, 0.7);
            --glass-border: rgba(255, 255, 255, 0.3);
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--background);
            color: var(--text-primary);
            margin: 0;
            overflow-x: hidden;
        }

        .admin-layout {
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar */
        .admin-sidebar {
            width: 260px;
            background-color: var(--surface);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
            z-index: 100;
        }

        .admin-brand {
            padding: 1.5rem;
            border-bottom: 1px solid var(--border);
        }

        .admin-brand h2 {
            color: var(--primary);
            font-size: 1.5rem;
            font-weight: 700;
            margin: 0;
        }

        .admin-nav {
            flex: 1;
            padding: 1.5rem 1rem;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .admin-nav-item {
            padding: 0.75rem 1rem;
            border-radius: 12px;
            color: var(--text-secondary);
            font-weight: 500;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            text-decoration: none !important;
        }

        .admin-nav-item i {
            margin-right: 0.75rem;
            width: 20px;
            text-align: center;
        }

        .admin-nav-item:hover {
            background-color: rgba(59, 130, 246, 0.05);
            color: var(--primary);
        }

        .admin-nav-item.active {
            background-color: rgba(59, 130, 246, 0.1);
            color: var(--primary);
            font-weight: 600;
        }

        .admin-sidebar-footer {
            padding: 1.5rem;
            border-top: 1px solid var(--border);
        }

        .admin-user-info {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .admin-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), #8b5cf6);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }

        .admin-name {
            font-weight: 600;
            font-size: 0.95rem;
        }

        .admin-role {
            font-size: 0.8rem;
            color: var(--text-secondary);
        }

        .admin-logout-btn {
            width: 100%;
            padding: 0.5rem;
            background: transparent;
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text-secondary);
            cursor: pointer;
            transition: all 0.2s;
        }

        .admin-logout-btn:hover {
            background-color: rgba(239, 68, 68, 0.1);
            color: #ef4444;
            border-color: rgba(239, 68, 68, 0.3);
        }

        /* Main Content */
        .admin-main {
            flex: 1;
            margin-left: 260px;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .admin-topbar {
            height: 72px;
            background-color: var(--glass-bg);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 2rem;
            position: sticky;
            top: 0;
            z-index: 90;
        }

        .admin-topbar-title {
            font-weight: 600;
            color: var(--text-secondary);
        }

        .admin-content {
            padding: 2rem;
            animation: fadeIn 0.4s ease-out;
        }

        /* Cards & UI Elements */
        .premium-card {
            background-color: var(--surface);
            border-radius: 20px;
            border: 1px solid var(--border);
            box-shadow: var(--shadow-sm);
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .premium-card:hover {
            box-shadow: var(--shadow);
        }

        .premium-table thead th {
            background-color: var(--background);
            border: none;
            color: var(--text-secondary);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.05em;
            padding: 1.25rem;
        }

        .premium-table td {
            padding: 1.25rem;
            vertical-align: middle;
            border-color: var(--border);
        }

        .btn-premium {
            border-radius: 12px;
            padding: 0.5rem 1.25rem;
            font-weight: 600;
            transition: all 0.2s;
            border: none;
        }

        .btn-premium-primary {
            background: linear-gradient(135deg, var(--primary), #2563eb);
            color: white;
        }

        .btn-premium-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>

<body>
    <div class="admin-layout">
        <!-- Sidebar -->
        <aside class="admin-sidebar">
            <div class="admin-brand">
                <h2>Sport Admin</h2>
            </div>
            <nav class="admin-nav">
                <a href="/admin" class="admin-nav-item {{#if isDashboard}}active{{/if}}">
                    <i class="fas fa-th-large"></i> Dashboard
                </a>
                <a href="/admin/category" class="admin-nav-item {{#if isCategory}}active{{/if}}">
                    <i class="fas fa-list"></i> Categories
                </a>
                <a href="/admin/product" class="admin-nav-item {{#if isProduct}}active{{/if}}">
                    <i class="fas fa-box"></i> Products
                </a>
                <a href="/admin/orders" class="admin-nav-item {{#if isOrders}}active{{/if}}">
                    <i class="fas fa-shopping-cart"></i> Orders
                </a>
                <a href="/admin/voucher" class="admin-nav-item {{#if isVoucher}}active{{/if}}">
                    <i class="fas fa-ticket-alt"></i> Vouchers
                </a>
                <a href="/admin/customers" class="admin-nav-item {{#if isCustomers}}active{{/if}}">
                    <i class="fas fa-users"></i> Customers
                </a>
                <a href="/admin/contact" class="admin-nav-item {{#if isContact}}active{{/if}}">
                    <i class="fas fa-envelope"></i> Messages
                </a>
                <a href="/admin/settings" class="admin-nav-item {{#if isSettings}}active{{/if}}">
                    <i class="fas fa-cog"></i> Settings
                </a>
            </nav>
            <div class="admin-sidebar-footer">
                <div class="admin-user-info">
                    <div class="admin-avatar">{{substring user.name 0 1}}</div>
                    <div>
                        <div class="admin-name">{{user.name}}</div>
                        <div class="admin-role">Administrator</div>
                    </div>
                </div>
                <button onclick="location.href='/admin/logout'" class="admin-logout-btn">
                    <i class="fas fa-sign-out-alt"></i> Đăng xuất
                </button>
                <a href="https://shopnhom7.netlify.app/" class="admin-logout-btn mt-2 bg-success text-center"
                    style="display: flex; align-items: center; justify-content: center; text-decoration: none; background-color: #10b981; color: white;">
                    <i class="fas fa-home mr-2"></i> Trang chủ
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="admin-main">
            <header class="admin-topbar">
                <div class="admin-topbar-title">Control Panel / {{title}}</div>
            </header>
            <div class="admin-content">
                {{{body}}}
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.bundle.min.js"></script>
</body>

</html>