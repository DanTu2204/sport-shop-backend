<div class="container-fluid pb-5">
    <div class="row px-xl-5">
        <!-- Carousel hình ảnh -->
        <div class="col-lg-5 mb-30">
            <div id="product-carousel" class="carousel slide" data-ride="carousel">
                <div class="carousel-inner bg-light">
                    <div class="carousel-item active">
                        <img class="w-100 h-100"
                            src="{{#if product.image}}{{product.image}}{{else}}img/product-1.jpg{{/if}}"
                            onerror="this.src='/img/product-1.jpg'" alt="{{product.name}}">
                    </div>
                </div>
                {{!-- Removed navigation arrows since we only have one image for now --}}
            </div>
        </div>

        <!-- Thông tin sản phẩm -->
        <div class="col-lg-7 h-auto mb-30">
            <div class="h-100 bg-light p-30">
                <h3>{{product.name}}</h3>

                <div class="d-flex mb-3">
                    <div class="text-primary mr-2">
                        {{#if product}}
                        {{#if product.stars}}
                        {{#times product.stars}}
                        <small class="fas fa-star"></small>
                        {{/times}}
                        {{else}}
                        <small class="far fa-star"></small>
                        <small class="far fa-star"></small>
                        <small class="far fa-star"></small>
                        <small class="far fa-star"></small>
                        <small class="far fa-star"></small>
                        {{/if}}
                        {{else}}
                        {{!-- Demo Stars --}}
                        <small class="fas fa-star"></small>
                        <small class="fas fa-star"></small>
                        <small class="fas fa-star"></small>
                        <small class="fas fa-star"></small>
                        <small class="fas fa-star-half-alt"></small>
                        {{/if}}
                    </div>
                    <small class="pt-1"><a href="#tab-pane-3" class="text-decoration-none text-dark"
                            id="review-link">({{reviewCount}} Đánh giá)</a></small>
                </div>

                <h3 class="font-weight-semi-bold mb-4">
                    {{formatCurrency product.price}}
                    {{#if product.oldPrice}}<small class="text-muted ml-2"><del>{{formatCurrency
                            product.oldPrice}}</del></small>{{/if}}
                </h3>

                <p class="mb-4">
                    {{#if product.description}}
                    {{product.description}}
                    {{else}}
                    Mô tả sản phẩm đang cập nhật.
                    {{/if}}
                </p>

                <!-- Size -->
                <div class="d-flex mb-3">
                    <strong class="text-dark mr-3">Kích cỡ:</strong>
                    {{#if product.size}}
                    <form>
                        <div class="custom-control custom-radio custom-control-inline">
                            <input type="radio" class="custom-control-input" id="size-1" name="size" checked>
                            <label class="custom-control-label" for="size-1">{{product.size}}</label>
                        </div>
                    </form>
                    {{else}}
                    <span class="text-muted">Freesize</span>
                    {{/if}}
                </div>

                <!-- Màu sắc -->
                <div class="d-flex mb-4">
                    <strong class="text-dark mr-3">Màu sắc:</strong>
                    {{#if product.color}}
                    <form>
                        <div class="custom-control custom-radio custom-control-inline">
                            <input type="radio" class="custom-control-input" id="color-1" name="color" checked>
                            <label class="custom-control-label" for="color-1">{{product.color}}</label>
                        </div>
                    </form>
                    {{else}}
                    <span class="text-muted">Màu chuẩn</span>
                    {{/if}}
                </div>

                <!-- Số lượng + Thêm vào giỏ -->
                <form class="d-flex align-items-center mb-4 pt-2" method="post" action="/cart/add">
                    <input type="hidden" name="id" value="{{product.id}}">
                    <input type="hidden" name="name" value="{{product.name}}">
                    <input type="hidden" name="price" value="{{product.price}}">
                    <input type="hidden" name="image" value="{{product.image}}">

                    <div class="input-group quantity mr-3" style="width: 130px;">
                        <div class="input-group-btn">
                            <button class="btn btn-primary btn-minus" type="button">
                                <i class="fa fa-minus"></i>
                            </button>
                        </div>
                        <input name="qty" type="text" class="form-control bg-secondary border-0 text-center" value="1">
                        <div class="input-group-btn">
                            <button class="btn btn-primary btn-plus" type="button">
                                <i class="fa fa-plus"></i>
                            </button>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary px-3">
                        <i class="fa fa-shopping-cart mr-1"></i> Thêm vào giỏ hàng
                    </button>
                </form>

                <!-- Chia sẻ -->
                <div class="d-flex pt-2">
                    <strong class="text-dark mr-2">Chia sẻ:</strong>
                    <div class="d-inline-flex">
                        <a class="text-dark px-2"><i class="fab fa-facebook-f"></i></a>
                        <a class="text-dark px-2"><i class="fab fa-twitter"></i></a>
                        <a class="text-dark px-2"><i class="fab fa-linkedin-in"></i></a>
                        <a class="text-dark px-2"><i class="fab fa-pinterest"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabs mô tả / thông tin / đánh giá -->
    <div class="row px-xl-5">
        <div class="col">
            <div class="bg-light p-30">
                <div class="nav nav-tabs mb-4">
                    <a class="nav-item nav-link text-dark active" data-toggle="tab" href="#tab-pane-1">Mô tả</a>

                    <a class="nav-item nav-link text-dark" data-toggle="tab" href="#tab-pane-3">Đánh giá
                        ({{product.reviews}})</a>
                </div>

                <div class="tab-content">
                    <!-- Mô tả -->
                    <div class="tab-pane fade show active" id="tab-pane-1">
                        <h4 class="mb-3">Mô tả sản phẩm</h4>
                        <p>{{product.description}}</p>
                    </div>



                    <!-- Đánh giá -->
                    <div class="tab-pane fade" id="tab-pane-3">
                        <div class="row">
                            <div class="col-md-6">
                                <h4 class="mb-4">{{product.reviews}} đánh giá cho "{{product.name}}"</h4>
                                {{#if reviews}}
                                {{#each reviews}}
                                <div class="media mb-4">
                                    <img src="/img/user.jpg" class="img-fluid mr-3 mt-1" style="width: 45px;"
                                        onerror="this.src='/img/user.jpg'">
                                    <div class="media-body">
                                        <h6>{{this.user.name}}
                                            <small> - <i>{{formatDate this.createdAt}}</i></small>
                                        </h6>
                                        <div class="text-primary mb-2">
                                            {{#times this.stars}}
                                            <i class="fas fa-star"></i>
                                            {{/times}}
                                        </div>
                                        <p>{{this.comment}}</p>
                                    </div>
                                </div>
                                {{/each}}
                                {{else}}
                                <p>Chưa có đánh giá nào.</p>
                                {{/if}}
                            </div>

                            <div class="col-md-6">
                                <h4 class="mb-4">Viết đánh giá của bạn</h4>
                                <form method="post" action="/products/{{#if product}}{{product.id}}{{/if}}/review">
                                    <div class="form-group">
                                        <label for="message">Nội dung *</label>
                                        <textarea id="message" name="comment" rows="5" class="form-control"
                                            required></textarea>
                                    </div>
                                    <div class="form-group">
                                        <label for="name">Tên *</label>
                                        <input type="text" class="form-control" id="name" name="name"
                                            value="{{#if ../user}}{{../user.name}}{{/if}}" {{#if
                                            ../user}}readonly{{/if}}>
                                    </div>
                                    <div class="form-group">
                                        <label for="email">Email *</label>
                                        <input type="email" class="form-control" id="email" name="email"
                                            value="{{#if ../user}}{{../user.email}}{{/if}}" {{#if
                                            ../user}}readonly{{/if}}>
                                    </div>
                                    <!-- Hidden Star Rating Default 5 -->
                                    <input type="hidden" name="stars" value="5">

                                    {{#if ../user}}
                                    <input type="submit" value="Gửi đánh giá" class="btn btn-primary px-3">
                                    {{else}}
                                    <a href="/login" class="btn btn-primary px-3">Đăng nhập để đánh giá</a>
                                    {{/if}}
                                </form>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<!-- Sản phẩm tương tự -->
<div class="container-fluid py-5">
    <h2 class="section-title position-relative text-uppercase mx-xl-5 mb-4">
        <span class="bg-secondary pr-3">Sản Phẩm Tương Tự</span>
    </h2>

    <div class="row px-xl-5">
        <div class="col">
            {{#if relatedProducts.length}}
            <div class="owl-carousel related-carousel">
                {{#each relatedProducts}}
                <div class="product-item bg-light">
                    <div class="product-img position-relative overflow-hidden">
                        <img class="img-fluid w-100" src="{{image}}" onerror="this.src='/img/product-1.jpg'"
                            alt="{{name}}">
                        <div class="product-action">
                            <form method="post" action="/cart/add" class="d-inline">
                                <input type="hidden" name="id" value="{{id}}">
                                <input type="hidden" name="name" value="{{name}}">
                                <input type="hidden" name="price" value="{{price}}">
                                <input type="hidden" name="image" value="{{image}}">
                                <button type="submit" class="btn btn-outline-dark btn-square"><i
                                        class="fa fa-shopping-cart"></i></button>
                            </form>
                            <a class="btn btn-outline-dark btn-square" href="/wishlist?add={{id}}"><i
                                    class="far fa-heart"></i></a>
                            <a class="btn btn-outline-dark btn-square" href="/detail?id={{id}}"><i
                                    class="fa fa-search"></i></a>
                        </div>
                    </div>

                    <div class="text-center py-4">
                        <a class="h6 text-decoration-none text-truncate" href="/detail?id={{id}}">{{name}}</a>
                        <div class="d-flex justify-content-center mt-2">
                            <h5>{{formatCurrency price}}</h5>
                            {{#if oldPrice}}
                            <h6 class="text-muted ml-2"><del>{{formatCurrency oldPrice}}</del></h6>
                            {{/if}}
                        </div>
                    </div>
                </div>
                {{/each}}
            </div>
            {{else}}
            <p class="text-muted">Chưa có sản phẩm tương tự.</p>
            {{/if}}
        </div>
    </div>

</div>

