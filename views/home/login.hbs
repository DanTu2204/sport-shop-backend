<div class="container-fluid py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 p-lg-5">
                    <h2 class="text-center mb-4">Đăng nhập</h2>

                    {{#if errors}}
                    <div class="alert alert-danger">
                        <ul class="mb-0 pl-3">
                            {{#each errors}}
                            <li>{{this}}</li>
                            {{/each}}
                        </ul>
                    </div>
                    {{/if}}

                    <form id="loginForm" data-redirect="{{next}}" data-endpoint="{{endpoint}}" method="post">
                        <input type="hidden" name="redirect" value="{{next}}">
                        <div class="form-group">
                            <label for="email">Email</label>
                            <input value="{{form.email}}" type="email" name="email" id="email" class="form-control"
                                placeholder="example@email.com" required>
                        </div>
                        <div class="form-group">
                            <label for="password">Mật khẩu</label>
                            <input type="password" name="password" id="password" class="form-control"
                                placeholder="******" required minlength="6">
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="1" id="rememberMe">
                                <label class="form-check-label" for="rememberMe">
                                    Ghi nhớ đăng nhập
                                </label>
                            </div>
                            <a href="#" class="text-primary">Quên mật khẩu?</a>
                        </div>
                        <button type="submit" class="btn btn-primary btn-block py-2">Đăng nhập</button>
                    </form>

                    <p class="text-center mt-3 mb-0">
                        Chưa có tài khoản?
                        <a href="/register" class="font-weight-bold">Đăng ký ngay</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- SCRIPT XỬ LÝ AJAX LOGIN -->
<script>
    $('#loginForm').submit(function (e) {
        e.preventDefault();
        const formData = $(this).serialize();
        const endpoint = $(this).data('endpoint');
        $.ajax({
            type: 'POST',
            url: endpoint,
            data: formData,
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            },
            success: function (response) {
                if (response.success) {
                    alert(response.message);
                    window.location.href = response.redirect || '/';
                } else {
                    alert('Lỗi đăng nhập: ' + response.message);
                }
            },
            error: function (xhr) {
                try {
                    const errorData = JSON.parse(xhr.responseText);
                    alert('Lỗi: ' + errorData.message);
                } catch (e) {
                    alert('Lỗi: Đã xảy ra lỗi không xác định. Vui lòng thử lại.');
                }
            }
        });
    });
</script>