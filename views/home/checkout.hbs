<!-- Checkout Start -->
<div class="container-fluid">
    <div class="row px-xl-5">

        <!-- Địa chỉ thanh toán -->
        <div class="col-lg-8">
            <h5 class="section-title position-relative text-uppercase mb-3">
                <span class="bg-secondary pr-3">Địa chỉ thanh toán</span>
            </h5>

            <form method="post" action="/checkout" id="checkoutForm">
                {{#if user}}
                <input type="hidden" name="user" value="{{json user}}" id="checkoutUser">
                {{/if}}
                {{#if cart}}
                <input type="hidden" name="cart" value="{{json cart}}" id="checkoutCart">
                {{/if}}
                {{#if wishlist}}
                <input type="hidden" name="wishlist" value="{{json wishlist}}" id="checkoutWishlist">
                {{/if}}
                <div class="bg-light p-30 mb-5">
                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label>Họ <span class="text-danger">*</span></label>
                            <input name="firstName" class="form-control" type="text" placeholder="Nguyễn" required>
                        </div>
                        <div class="col-md-6 form-group">
                            <label>Tên <span class="text-danger">*</span></label>
                            <input name="lastName" class="form-control" type="text" placeholder="Văn A" required>
                        </div>

                        <div class="col-md-6 form-group">
                            <label>Email <span class="text-danger">*</span></label>
                            <input name="email" class="form-control" type="email" placeholder="example@gmail.com"
                                required>
                        </div>
                        <div class="col-md-6 form-group">
                            <label>Số điện thoại <span class="text-danger">*</span></label>
                            <input name="phone" class="form-control" type="text" placeholder="0396554056" required>
                        </div>

                        <div class="col-md-12 form-group">
                            <label>Địa chỉ giao hàng <span class="text-danger">*</span></label>
                            <input name="address" class="form-control" type="text"
                                placeholder="123 Lê Lợi, Quận 1, TP. Hồ Chí Minh" required>
                        </div>

                        <div class="col-md-6 form-group">
                            <label>Tỉnh/Thành phố <span class="text-danger">*</span></label>
                            <input name="city" class="form-control" type="text" placeholder="TP. Hồ Chí Minh" required>
                        </div>
                        <div class="col-md-6 form-group">
                            <label>Quận/Huyện <span class="text-danger">*</span></label>
                            <input name="district" class="form-control" type="text" placeholder="Quận 1" required>
                        </div>

                        <div class="col-md-12 form-group">
                            <div class="custom-control custom-checkbox">
                                <input type="checkbox" class="custom-control-input" id="createAccount">
                                <label class="custom-control-label" for="createAccount">Tạo tài khoản mới</label>
                            </div>
                        </div>

                        <div class="col-md-12 form-group">
                            <div class="custom-control custom-checkbox">
                                <input type="checkbox" class="custom-control-input" id="shipto">
                                <label class="custom-control-label" for="shipto" data-toggle="collapse"
                                    data-target="#shipping-address">
                                    Giao hàng đến địa chỉ khác
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Địa chỉ giao hàng khác -->
                <div class="collapse mb-5" id="shipping-address">
                    <h5 class="section-title position-relative text-uppercase mb-3">
                        <span class="bg-secondary pr-3">Địa chỉ giao hàng</span>
                    </h5>

                    <div class="bg-light p-30">
                        <div class="row">
                            <div class="col-md-6 form-group">
                                <label>Họ</label>
                                <input class="form-control" type="text" placeholder="Nguyễn">
                            </div>
                            <div class="col-md-6 form-group">
                                <label>Tên</label>
                                <input class="form-control" type="text" placeholder="Thị B">
                            </div>

                            <div class="col-md-6 form-group">
                                <label>Email</label>
                                <input class="form-control" type="email" placeholder="example@gmail.com">
                            </div>
                            <div class="col-md-6 form-group">
                                <label>Số điện thoại</label>
                                <input class="form-control" type="text" placeholder="0909 456 789">
                            </div>

                            <div class="col-md-12 form-group">
                                <label>Địa chỉ</label>
                                <input class="form-control" type="text"
                                    placeholder="456 Nguyễn Trãi, Quận 5, TP. Hồ Chí Minh">
                            </div>
                        </div>
                    </div>
                </div>
        <div>
    </div>

    <!-- Tổng đơn hàng -->
    <div class="col-lg-4">

        <h5 class="section-title position-relative text-uppercase mb-3">
            <span class="bg-secondary pr-3">Tổng đơn hàng</span>
        </h5>

        <div class="bg-light p-30 mb-5">
            <div class="border-bottom">
                <h6 class="mb-3">Sản phẩm</h6>
                {{#if cart}}
                {{#each cart}}
                <div class="d-flex justify-content-between mb-2">
                    <p class="mb-0">{{name}} <small class="text-muted">x{{qty}}</small></p>
                    <p class="mb-0">{{formatCurrency (multiply price qty)}}</p>
                </div>
                {{/each}}
                {{else}}
                <p class="text-muted">Giỏ hàng trống</p>
                {{/if}}
            </div>

            <div class="border-bottom pt-3 pb-2">
                <div class="d-flex justify-content-between mb-3">
                    <h6>Tạm tính</h6>
                    <h6>{{formatCurrency subtotal}}</h6>
                </div>
                <!-- Voucher Input -->
                <div class="input-group mb-3">
                    <input type="text" class="form-control" name="voucherCode" id="voucherCodeInput"
                        placeholder="Mã giảm giá" value="{{voucherCode}}">
                    <div class="input-group-append">
                        <button class="btn btn-primary" type="button" id="applyVoucherBtn">Áp dụng</button>
                    </div>
                </div>
                <div id="voucherMessage" class="mb-2"></div>

                {{#if discountAmount}}
                <div class="d-flex justify-content-between mb-3 text-success">
                    <h6>Giảm giá</h6>
                    <h6>-{{formatCurrency discountAmount}}</h6>
                </div>
                {{/if}}

                <div class="d-flex justify-content-between">
                    <h6 class="font-weight-medium">Phí vận chuyển</h6>
                    <h6 class="font-weight-medium">{{formatCurrency shipping}}</h6>
                </div>
            </div>

            <div class="pt-2">
                <div class="d-flex justify-content-between mt-2">
                    <h5>Tổng cộng</h5>
                    <h5>{{formatCurrency grandTotal}}</h5>
                </div>
            </div>
        </div>

        <!-- Phương thức thanh toán -->
        <div class="mb-5">
            <h5 class="section-title position-relative text-uppercase mb-3">
                <span class="bg-secondary pr-3">Phương thức thanh toán</span>
            </h5>

            <div class="bg-light p-30">

                <div class="form-group">
                    <div class="custom-control custom-radio">
                        <input type="radio" class="custom-control-input" name="paymentMethod" id="cod" value="cod"
                            checked required>
                        <label class="custom-control-label" for="cod">Thanh toán khi nhận hàng (COD)</label>
                    </div>
                </div>

                <div class="form-group">
                    <div class="custom-control custom-radio">
                        <input type="radio" class="custom-control-input" name="paymentMethod" id="banktransfer"
                            value="banktransfer" required>
                        <label class="custom-control-label" for="banktransfer">Chuyển khoản ngân hàng</label>
                    </div>
                </div>

                <div class="form-group mb-4">
                    <div class="custom-control custom-radio">
                        <input type="radio" class="custom-control-input" name="paymentMethod" id="momo" value="momo"
                            required>
                        <label class="custom-control-label" for="momo">Thanh toán qua Momo / ZaloPay</label>
                    </div>
                </div>

                <button type="submit" class="btn btn-block btn-primary font-weight-bold py-3">Xác nhận đặt hàng</button>
            </div>
        </div>
    </div>
    </form>
</div>
<!-- Checkout End -->
<script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.bundle.min.js"></script>
<script src="https://kit.fontawesome.com/a076d05399.js"></script>
<script>
    $(document).ready(function () {
        $('#applyVoucherBtn').click(function () {
            const code = $('#voucherCodeInput').val();
            if (!code) {
                alert('Vui lòng nhập mã giảm giá');
                return;
            }

            $.ajax({
                url: '/cart/apply-voucher',
                method: 'POST',
                data: { code: code },
                success: function (response) {
                    if (response.success) {
                        $('#voucherMessage').html('<small class="text-success">' + response.message + '</small>');
                        location.reload(); // Reload to update totals
                    } else {
                        $('#voucherMessage').html('<small class="text-danger">' + response.message + '</small>');
                    }
                },
                error: function () {
                    $('#voucherMessage').html('<small class="text-danger">Có lỗi xảy ra, vui lòng thử lại.</small>');
                }
            });
        });
    });
</script>

