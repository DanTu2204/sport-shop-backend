<div class="container-fluid">
    <div class="row px-xl-5">
        <div class="col-12">
            <nav class="breadcrumb bg-light mb-30">
                <a class="breadcrumb-item text-dark" href="/">Trang chủ</a>
                <span class="breadcrumb-item active">Đơn hàng của tôi</span>
            </nav>
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="row px-xl-5">
        <div class="col-lg-12 table-responsive mb-5">
            <h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3">Lịch sử đơn
                    hàng</span></h5>
            {{#if orders}}
            <table class="table table-light table-borderless table-hover text-center mb-0">
                <thead class="thead-dark">
                    <tr>
                        <th>Mã đơn hàng</th>
                        <th>Ngày đặt</th>
                        <th>Sản phẩm</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th>Chi tiết</th>
                    </tr>
                </thead>
                <tbody class="align-middle">
                    {{#each orders}}
                    <tr>
                        <td class="align-middle">{{_id}}</td>
                        <td class="align-middle">{{this.createdAtFormatted}}</td>
                        <td class="align-middle text-left">
                            <ul class="list-unstyled mb-0">
                                {{#each items}}
                                <li>- {{name}} x{{quantity}}</li>
                                {{/each}}
                            </ul>
                        </td>
                        <td class="align-middle">
                            {{formatCurrency totalPrice}}
                            {{#if discount}}
                            <br><small class="text-success">(Đã giảm: {{formatCurrency discount}})</small>
                            {{/if}}
                        </td>
                        <td class="align-middle">
                            {{#if_eq status 'pending'}}
                            <span class="badge badge-warning">Đang xử lý</span>
                            {{/if_eq}}
                            {{#if_eq status 'confirmed'}}
                            <span class="badge badge-info">Đã xác nhận</span>
                            {{/if_eq}}
                            {{#if_eq status 'shipping'}}
                            <span class="badge badge-primary">Đang giao</span>
                            {{/if_eq}}
                            {{#if_eq status 'completed'}}
                            <span class="badge badge-success">Hoàn thành</span>
                            {{/if_eq}}
                            {{#if_eq status 'cancelled'}}
                            <span class="badge badge-danger">Đã hủy</span>
                            {{/if_eq}}
                        </td>
                        <td class="align-middle">
                            <a href="/orders/{{_id}}" class="btn btn-sm btn-primary">Xem</a>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
            {{else}}
            <div class="text-center py-5">
                <h4 class="text-muted">Bạn chưa có đơn hàng nào.</h4>
                <a href="/shop" class="btn btn-primary mt-3">Mua sắm ngay</a>
            </div>
            {{/if}}
        </div>
    </div>
</div>