<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <style>
        body {
            background-color: #f8f9fa;
            padding-top: 50px;
        }

        .container {
            background: #fff;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        }

        .header {
            border-bottom: 2px solid #007bff;
            margin-bottom: 30px;
            padding-bottom: 10px;
        }

        .btn-add {
            margin-bottom: 20px;
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="header d-flex justify-content-between align-items-center">
            <h2>User Management Demo</h2>
            <a href="/" class="btn btn-outline-secondary btn-sm">Quay lại API</a>
        </div>

        <!-- Form Thêm Mới -->
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">Thêm Người Dùng Mới</div>
            <div class="card-body">
                <form action="/demo/add" method="POST" class="form-row">
                    <div class="form-group col-md-3">
                        <input type="text" name="name" class="form-control" placeholder="Họ tên" required>
                    </div>
                    <div class="form-group col-md-3">
                        <input type="email" name="email" class="form-control" placeholder="Email" required>
                    </div>
                    <div class="form-group col-md-2">
                        <input type="text" name="phone" class="form-control" placeholder="Số điện thoại">
                    </div>
                    <div class="form-group col-md-2">
                        <select name="role" class="form-control">
                            <option value="user">User</option>
                            <option value="admin">Admin</option>
                        </select>
                    </div>
                    <div class="form-group col-md-2">
                        <button type="submit" class="btn btn-success btn-block">Thêm</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Bảng Danh Sách -->
        <table class="table table-bordered table-hover">
            <thead class="thead-dark">
                <tr>
                    <th>ID</th>
                    <th>Tên</th>
                    <th>Email</th>
                    <th>SĐT</th>
                    <th>Quyền</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                {{#each users}}
                <tr>
                    <td><small>{{this._id}}</small></td>
                    <form action="/demo/edit/{{this._id}}" method="POST" id="edit-form-{{this._id}}">
                        <td><input type="text" name="name" value="{{this.name}}" class="form-control form-control-sm">
                        </td>
                        <td><input type="email" name="email" value="{{this.email}}"
                                class="form-control form-control-sm"></td>
                        <td><input type="text" name="phone" value="{{this.phone}}" class="form-control form-control-sm">
                        </td>
                        <td>
                            <select name="role" class="form-control form-control-sm">
                                <option value="user" {{#if (eq this.role "user" )}}selected{{/if}}>User</option>
                                <option value="admin" {{#if (eq this.role "admin" )}}selected{{/if}}>Admin</option>
                            </select>
                        </td>
                    </form>
                    <td>
                        <div class="btn-group">
                            <button type="submit" form="edit-form-{{this._id}}"
                                class="btn btn-primary btn-sm">Lưu</button>
                            <form action="/demo/delete/{{this._id}}" method="POST"
                                onsubmit="return confirm('Xóa người dùng này?')">
                                <button type="submit" class="btn btn-danger btn-sm">Xóa</button>
                            </form>
                        </div>
                    </td>
                </tr>
                {{/each}}
                {{#unless users}}
                <tr>
                    <td colspan="6" class="text-center">Chưa có người dùng nào.</td>
                </tr>
                {{/unless}}
            </tbody>
        </table>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.5.4/dist/umd/popper.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
</body>

</html>